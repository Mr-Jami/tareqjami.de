---
import Base from '../layouts/Base.astro';

// German is the legally authoritative version; English is a convenience translation.
const title = 'Impressum — Tareq Jami';
const description = 'Impressum / legal notice for Jami IT (Tareq Jami), Hamburg.';
---

<Base title={title} description={description} canonical="https://tareqjami.de/impressum/">
  <nav slot="nav" class="nav">
    <a href="/" class="nav-link"
      >← <span data-lang-block="en">Home</span><span data-lang-block="de">Start</span></a
    >
  </nav>

  <main id="main">
    <article class="legal">
      <!-- German (authoritative) -->
      <div data-lang-block="de">
        <h1>Impressum</h1>

        <h2>Angaben gemäß § 5 DDG</h2>
        <p class="addr">
          Jami IT<br />
          Inhaber: Tareq Jami<br />
          Walddörferstraße 104<br />
          22041 Hamburg<br />
          Deutschland
        </p>

        <h2>Kontakt</h2>
        <p>E-Mail: <a href="mailto:info@jami-it.de">info@jami-it.de</a></p>

        <h2>Umsatzsteuer-Identifikationsnummer</h2>
        <p>
          Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
          DE406600643
        </p>

        <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p class="addr">
          Tareq Jami<br />
          Walddörferstraße 104<br />
          22041 Hamburg
        </p>

        <h2>Verbraucherstreitbeilegung / Universalschlichtungsstelle</h2>
        <p>
          Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor
          einer Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </div>

      <!-- English (convenience translation) -->
      <div data-lang-block="en">
        <h1>Legal Notice</h1>

        <h2>Information pursuant to § 5 DDG</h2>
        <p class="addr">
          Jami IT<br />
          Owner: Tareq Jami<br />
          Walddörferstraße 104<br />
          22041 Hamburg<br />
          Germany
        </p>

        <h2>Contact</h2>
        <p>Email: <a href="mailto:info@jami-it.de">info@jami-it.de</a></p>

        <h2>VAT identification number</h2>
        <p>
          VAT identification number pursuant to § 27 a of the German VAT Act (UStG):<br />
          DE406600643
        </p>

        <h2>Responsible for content pursuant to § 18 (2) MStV</h2>
        <p class="addr">
          Tareq Jami<br />
          Walddörferstraße 104<br />
          22041 Hamburg
        </p>

        <h2>Consumer dispute resolution</h2>
        <p>
          We are not willing or obliged to participate in dispute resolution
          proceedings before a consumer arbitration board.
        </p>

        <p class="note">
          This English translation is provided for convenience. The German version
          is legally binding.
        </p>
      </div>
    </article>
  </main>

  <script>
    import { initControls } from '../lib/ui';

    const titles = { en: 'Legal Notice — Tareq Jami', de: 'Impressum — Tareq Jami' };

    document.addEventListener('langchange', (e) => {
      const lang = (e as CustomEvent<{ lang: 'en' | 'de' }>).detail.lang;
      document.title = titles[lang];
    });

    initControls();
  </script>
</Base>
